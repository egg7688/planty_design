PORT=3000
MAX_RESULTS=5

# DBpia OpenAPI
# https://api.dbpia.co.kr/openApi/about/intro.do 에서 발급
DBPIA_API_KEY=
DBPIA_API_URL=http://api.dbpia.co.kr/v2/search/search.xml

# Google Scholar compatible API
# Google Scholar 공식 API는 없으므로 SerpApi의 google_scholar 엔진을 기본값으로 사용합니다.
SERPAPI_API_KEY=
GOOGLE_SCHOLAR_API_URL=https://serpapi.com/search.json
GOOGLE_SCHOLAR_LANG=ko

# SMTP email delivery
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=
