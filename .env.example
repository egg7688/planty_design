PORT=3000
MAX_RESULTS=5

# Premium access gate
# 개발 환경에서 비워두면 demo-premium 코드로 테스트할 수 있습니다.
PREMIUM_ACCESS_CODE=
PREMIUM_SESSION_TTL_HOURS=12
SESSION_SECRET=

# DBpia OpenAPI
# https://api.dbpia.co.kr/openApi/about/intro.do 에서 발급
DBPIA_API_KEY=
DBPIA_API_URL=http://api.dbpia.co.kr/v2/search/search.xml

# Google Scholar compatible API
# Google Scholar 공식 API는 없으므로 SerpApi의 google_scholar 엔진을 기본값으로 사용합니다.
SERPAPI_API_KEY=
GOOGLE_SCHOLAR_API_URL=https://serpapi.com/search.json
GOOGLE_SCHOLAR_LANG=ko

# AI report summarization
# 비워두면 검색 결과 기반 규칙형 요약을 사용합니다.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# SMTP email delivery
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=
