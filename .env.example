PORT=3000
MAX_RESULTS=5

# Premium access gate
# DBpia 기관인증 완료 확인 흐름을 기본으로 사용합니다.
# 별도 접근 코드 방식도 유지하려면 값을 설정하세요.
PREMIUM_ACCESS_CODE=
PREMIUM_SESSION_TTL_HOURS=12
SESSION_SECRET=

# DBpia OpenAPI
# https://api.dbpia.co.kr/openApi/about/intro.do 에서 발급
DBPIA_API_KEY=
DBPIA_API_URL=http://api.dbpia.co.kr/v2/search/search.xml

# AI report summarization
# 비워두면 검색 결과 기반 규칙형 요약을 사용합니다.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# SMTP email delivery
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=
